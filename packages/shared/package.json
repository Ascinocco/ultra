{
  "name": "@ultra/shared",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./skills": {
      "types": "./dist/generated/bundled-skills.d.ts",
      "import": "./dist/generated/bundled-skills.js",
      "default": "./dist/generated/bundled-skills.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check package.json tsconfig.json tsconfig.build.json src",
    "test": "vitest run src/index.test.ts"
  },
  "dependencies": {
    "zod": "4.1.11"
  }
}
