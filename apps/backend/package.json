{
  "name": "@ultra/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm --filter @ultra/shared build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "biome check package.json tsconfig.json tsconfig.build.json src",
    "test": "vitest run"
  },
  "dependencies": {
    "@ultra/shared": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "tsx": "4.21.0"
  }
}
